{
  "Ansible Playbook": {
    "prefix": "ans_play",
    "body": [
      "---",
      "- name: ${1:Nom du playbook}",
      "  hosts: ${2:all}",
      "  become: ${3:true}",
      "  gather_facts: ${4:true}",
      "",
      "  tasks:",
      "    - name: ${5:Task principale}",
      "      ${6:module}:",
      "        ${7:option}: ${8:valeur}"
    ]
  },
  "Ansible Task": {
    "prefix": "ans_task",
    "body": [
      "- name: ${1:Description}",
      "  ${2:module}:",
      "    ${3:option}: ${4:valeur}",
      "  when: ${5:condition}"
    ]
  },
  "Ansible Install Package": {
    "prefix": "ans_pkg",
    "body": [
      "- name: Installer ${1:package}",
      "  ansible.builtin.package:",
      "    name: $1",
      "    state: ${2:present}",
      "  become: true"
    ]
  },
  "Ansible Service": {
    "prefix": "ans_service",
    "body": [
      "- name: ${1:Gérer} le service ${2:service}",
      "  ansible.builtin.service:",
      "    name: $2",
      "    state: ${3:started}",
      "    enabled: ${4:true}",
      "  become: true"
    ]
  },
  "Ansible Copy": {
    "prefix": "ans_copy",
    "body": [
      "- name: Copier ${1:fichier}",
      "  ansible.builtin.copy:",
      "    src: ${2:source}",
      "    dest: ${3:destination}",
      "    owner: ${4:root}",
      "    mode: '${5:0644}'",
      "  become: true"
    ]
  },
  "Ansible Debug": {
    "prefix": "ans_debug",
    "body": [
      "- name: Debug ${1:variable}",
      "  ansible.builtin.debug:",
      "    msg: \"{{ $1 }}\""
    ]
  },
  "Ansible Handler": {
    "prefix": "ans_handler",
    "body": [
      "- name: ${1:handler}",
      "  ansible.builtin.service:",
      "    name: ${2:service}",
      "    state: ${3:restarted}"
    ]
  },
  "Ansible Block Rescue Always": {
    "prefix": "ans_block",
    "body": [
      "- name: ${1:Block}",
      "  block:",
      "    - name: ${2:Task}",
      "      ${3:module}:",
      "  rescue:",
      "    - name: Erreur",
      "      ansible.builtin.debug:",
      "        msg: \"Erreur\"",
      "  always:",
      "    - name: Toujours",
      "      ansible.builtin.debug:",
      "        msg: \"Terminé\""
    ]
  },
  "Ansible Register and Conditional": {
    "prefix": "ans_reg",
    "body": [
      "- name: ${1:Commande}",
      "  ansible.builtin.command: ${2:cmd}",
      "  register: ${3:result}",
      "  changed_when: false",
      "",
      "- name: ${4:Task conditionnelle}",
      "  ${5:module}:",
      "  when: $3.rc == 0"
    ]
  }
}
